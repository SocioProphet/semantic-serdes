{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.example/schemas/symbol_cell.schema.json",
  "title": "SymbolCell",
  "type": "object",
  "required": ["cell_id", "object_kind", "symbol_id", "bundle_ref", "symbol_kind", "semantic_hypotheses", "provenance", "governance"],
  "properties": {
    "cell_id": {"type": "string", "minLength": 1},
    "object_kind": {"const": "SYMBOL"},
    "symbol_id": {"type": "string"},
    "bundle_ref": {"type": "string"},
    "symbol_kind": {"enum": ["IMPORT", "DECLARATION", "FUNCTION", "CLASS", "EXPORT", "UNKNOWN"]},
    "section_ref": {"type": "string"},
    "display_label": {"type": "string"},
    "recovered_label": {"type": "string"},
    "static_features": {
      "type": "object",
      "properties": {
        "parameter_count": {"type": "integer", "minimum": 0},
        "literal_affinity": {"type": "array", "items": {"type": "string"}},
        "call_degree": {"type": "integer", "minimum": 0},
        "exported": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "semantic_hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "confidence"],
        "properties": {
          "label": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "basis_refs": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "provenance": {
      "type": "object",
      "required": ["source_refs"],
      "properties": {
        "source_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "hashes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": ["admissibility_tier"],
      "properties": {
        "admissibility_tier": {"enum": ["RAW", "VALIDATED", "GOVERNED", "CANONICAL", "CONTESTED"]},
        "review_required": {"type": "boolean"},
        "status": {"enum": ["NORMAL", "APPROXIMATE", "CONTESTED", "SUPERSEDED"]}
      },
      "additionalProperties": false
    },
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}