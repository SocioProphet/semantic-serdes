{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.example/schemas/code_bundle_cell.schema.json",
  "title": "CodeBundleCell",
  "type": "object",
  "required": ["cell_id", "object_kind", "bundle_label", "language", "section_refs", "provenance", "governance"],
  "properties": {
    "cell_id": {"type": "string", "minLength": 1},
    "object_kind": {"const": "CODE_BUNDLE"},
    "bundle_label": {"type": "string"},
    "language": {"enum": ["JAVASCRIPT", "TYPESCRIPT", "PYTHON", "OTHER"]},
    "import_refs": {"type": "array", "items": {"type": "string"}},
    "section_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "export_refs": {"type": "array", "items": {"type": "string"}},
    "semantic_posture": {"enum": ["NAVIGATION_ORIENTED", "SEMANTIC_RECOVERY", "RUNTIME_AUGMENTED"]},
    "provenance": {
      "type": "object",
      "required": ["source_refs"],
      "properties": {
        "source_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "hashes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": ["admissibility_tier"],
      "properties": {
        "admissibility_tier": {"enum": ["RAW", "VALIDATED", "GOVERNED", "CANONICAL", "CONTESTED"]},
        "review_required": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}