{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.example/schemas/recovery_claim.schema.json",
  "title": "RecoveryClaim",
  "type": "object",
  "required": ["claim_id", "bundle_ref", "target_ref", "claim_kind", "claim_label", "confidence", "basis_refs", "provenance", "governance"],
  "properties": {
    "claim_id": {"type": "string", "minLength": 1},
    "bundle_ref": {"type": "string"},
    "target_ref": {"type": "string"},
    "claim_kind": {"enum": ["SYMBOL_ROLE", "SUBSYSTEM_ROLE", "NETWORK_BEHAVIOR", "STORAGE_BEHAVIOR", "STATE_BOUNDARY", "FEATURE_FLAG", "OTHER"]},
    "claim_label": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "basis_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "supersedes": {"type": "array", "items": {"type": "string"}},
    "runtime_witness_refs": {"type": "array", "items": {"type": "string"}},
    "provenance": {
      "type": "object",
      "required": ["source_refs"],
      "properties": {
        "source_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "hashes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": ["admissibility_tier"],
      "properties": {
        "admissibility_tier": {"enum": ["RAW", "VALIDATED", "GOVERNED", "CANONICAL", "CONTESTED"]},
        "review_required": {"type": "boolean"},
        "status": {"enum": ["PROPOSED", "SUPPORTED", "CONTESTED", "SUPERSEDED"]}
      },
      "additionalProperties": false
    },
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}