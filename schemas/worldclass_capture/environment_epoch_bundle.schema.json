{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.example/schemas/environment_epoch_bundle.schema.json",
  "title": "EnvironmentEpochBundle",
  "type": "object",
  "required": [
    "environment_id",
    "epoch_id",
    "artifact_roots",
    "runtime_roots",
    "scaffold_roots",
    "toolchain_refs",
    "policy_refs",
    "provenance",
    "governance"
  ],
  "properties": {
    "environment_id": {
      "type": "string",
      "minLength": 1
    },
    "epoch_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_roots": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "runtime_roots": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "scaffold_roots": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "toolchain_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "environment_handles": {
      "type": "object",
      "properties": {
        "artifact_h": {
          "type": "string"
        },
        "runtime_h": {
          "type": "string"
        },
        "scaffold_h": {
          "type": "string"
        },
        "toolchain_h": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "policy_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "provenance": {
      "type": "object",
      "required": [
        "source_refs"
      ],
      "properties": {
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "hashes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": [
        "admissibility_tier"
      ],
      "properties": {
        "admissibility_tier": {
          "enum": [
            "RAW",
            "VALIDATED",
            "GOVERNED",
            "CANONICAL",
            "CONTESTED"
          ]
        },
        "review_required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}