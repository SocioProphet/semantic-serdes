{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.dev/schemas/semantic-serdes/ontology_linking_candidate.schema.json",
  "title": "OntologyLinkingCandidate",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "source_field", "candidate_mappings", "decision", "evidence"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {"const": "security-rpm.socioprophet.dev/v0.1"},
    "kind": {"const": "OntologyLinkingCandidate"},
    "metadata": {
      "type": "object",
      "required": ["id", "status"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^ontology-link:"},
        "status": {"type": "string", "enum": ["candidate", "requires_review", "accepted", "rejected"]},
        "parser_id": {"type": "string"}
      }
    },
    "source_field": {
      "type": "object",
      "required": ["raw_name", "source_context"],
      "additionalProperties": false,
      "properties": {
        "raw_name": {"type": "string", "minLength": 1},
        "source_context": {"type": "string", "minLength": 1},
        "observed_values": {"type": "array", "items": {"type": "string"}},
        "neighbor_fields": {"type": "array", "items": {"type": "string"}}
      }
    },
    "candidate_mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ontology_field", "score"],
        "additionalProperties": false,
        "properties": {
          "ontology_field": {"type": "string", "minLength": 1},
          "score": {"type": "number", "minimum": 0, "maximum": 1},
          "target_system": {"type": "string", "enum": ["udm", "ontogenesis", "custom"]},
          "rationale": {"type": "string"}
        }
      }
    },
    "decision": {
      "type": "object",
      "required": ["state"],
      "additionalProperties": false,
      "properties": {
        "state": {"type": "string", "enum": ["accept", "reject", "require_review", "defer"]},
        "selected_mapping": {"type": "string"},
        "review_reason": {"type": "string"}
      }
    },
    "evidence": {
      "type": "object",
      "required": ["preimage_refs", "lossiness_profile"],
      "additionalProperties": false,
      "properties": {
        "preimage_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "lossiness_profile": {"type": "string", "minLength": 1},
        "examples": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
