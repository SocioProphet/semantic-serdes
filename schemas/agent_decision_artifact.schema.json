{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentDecisionArtifact",
  "type": "object",
  "required": [
    "decision_id",
    "decision_subject",
    "outcome",
    "issued_by",
    "supporting_messages",
    "alternatives",
    "review"
  ],
  "properties": {
    "decision_id": {
      "$ref": "#/$defs/identifier"
    },
    "decision_subject": {
      "type": "string"
    },
    "outcome": {
      "enum": [
        "ACCEPT",
        "REJECT",
        "ESCALATE",
        "DEFER",
        "CONTEST"
      ]
    },
    "issued_by": {
      "type": "string"
    },
    "supporting_messages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "alternative_id",
          "summary",
          "status"
        ],
        "properties": {
          "alternative_id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "status": {
            "enum": [
              "PREFERRED",
              "CONSERVATIVE",
              "EXTENSION_OF_CURRENT_STACK",
              "REJECTED"
            ]
          },
          "tradeoffs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "NOT_REQUIRED",
            "REQUIRED",
            "PENDING",
            "APPROVED",
            "REJECTED",
            "ESCALATED"
          ]
        },
        "required_roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approved_by": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "lineage": {
      "$ref": "#/$defs/lineage"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "kvObject": {
      "type": "object",
      "additionalProperties": true
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "source_type",
        "source_ref"
      ],
      "properties": {
        "source_type": {
          "type": "string"
        },
        "source_ref": {
          "type": "string"
        },
        "vendor_name": {
          "type": "string"
        },
        "product_name": {
          "type": "string"
        },
        "feed_family": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "hashes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "witness_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "lineage": {
      "type": "object",
      "properties": {
        "parent_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "branch_id": {
          "type": "string"
        },
        "replay_id": {
          "type": "string"
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}