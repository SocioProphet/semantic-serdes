{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentMessage",
  "type": "object",
  "required": [
    "message_id",
    "sender",
    "recipient",
    "sent_at",
    "delivery_semantics",
    "subject",
    "payload_ref",
    "governance"
  ],
  "properties": {
    "message_id": {
      "$ref": "#/$defs/identifier"
    },
    "sender": {
      "type": "string"
    },
    "recipient": {
      "type": "string"
    },
    "sent_at": {
      "$ref": "#/$defs/timestamp"
    },
    "delivery_semantics": {
      "enum": [
        "AT_MOST_ONCE",
        "AT_LEAST_ONCE",
        "EXACTLY_ONCE",
        "REPLAYABLE"
      ]
    },
    "subject": {
      "type": "string"
    },
    "payload_ref": {
      "type": "string"
    },
    "semantic_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capability_tokens": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "freshness_deadline": {
      "$ref": "#/$defs/timestamp"
    },
    "branch_id": {
      "type": "string"
    },
    "witness_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "governance": {
      "type": "object",
      "required": [
        "admissibility_tier",
        "review_status"
      ],
      "properties": {
        "admissibility_tier": {
          "enum": [
            "RAW",
            "VALIDATED",
            "GOVERNED",
            "CANONICAL"
          ]
        },
        "review_status": {
          "enum": [
            "NOT_REQUIRED",
            "REQUIRED",
            "PENDING",
            "APPROVED",
            "REJECTED",
            "ESCALATED"
          ]
        },
        "policy_basis": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "replay": {
      "type": "object",
      "properties": {
        "replayable": {
          "type": "boolean"
        },
        "message_hash": {
          "type": "string"
        },
        "config_hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "kvObject": {
      "type": "object",
      "additionalProperties": true
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "source_type",
        "source_ref"
      ],
      "properties": {
        "source_type": {
          "type": "string"
        },
        "source_ref": {
          "type": "string"
        },
        "vendor_name": {
          "type": "string"
        },
        "product_name": {
          "type": "string"
        },
        "feed_family": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "hashes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "witness_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "lineage": {
      "type": "object",
      "properties": {
        "parent_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "branch_id": {
          "type": "string"
        },
        "replay_id": {
          "type": "string"
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}