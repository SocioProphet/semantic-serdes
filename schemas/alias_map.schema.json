{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.example/schemas/alias_map.schema.json",
  "title": "AliasMap",
  "type": "object",
  "required": [
    "alias_group_id",
    "canonical_term",
    "aliases"
  ],
  "properties": {
    "alias_group_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_term": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "term",
          "kind"
        ],
        "properties": {
          "term": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "COMPATIBILITY",
              "LEGACY_VENDOR",
              "DOC_VARIANT",
              "QUERY_ALIAS",
              "DEPRECATED"
            ]
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "validity": {
            "type": "object",
            "properties": {
              "start": {
                "type": "string",
                "format": "date-time"
              },
              "end": {
                "type": "string",
                "format": "date-time"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}