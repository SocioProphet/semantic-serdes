{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SHIRLinkageCandidate",
  "type": "object",
  "required": [
    "linkage_id",
    "kind",
    "linkage_type",
    "candidate_status",
    "left",
    "right",
    "evidence",
    "confidence",
    "curation",
    "governance",
    "replay"
  ],
  "properties": {
    "linkage_id": { "$ref": "#/$defs/identifier" },
    "kind": { "const": "LinkageCandidate" },
    "linkage_type": {
      "enum": ["IDENTITY", "JOIN", "UNION", "SUBSET", "CROSSWALK", "SEMANTIC_OVERLAP", "SCHEMA_ALIGNMENT"]
    },
    "candidate_status": {
      "enum": ["PROPOSED", "REVIEW_REQUIRED", "APPROVED", "REJECTED", "QUARANTINED", "SUPERSEDED"]
    },
    "left": { "$ref": "#/$defs/endpoint" },
    "right": { "$ref": "#/$defs/endpoint" },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "curation": { "$ref": "#/$defs/curation" },
    "governance": { "$ref": "#/$defs/governance" },
    "replay": { "$ref": "#/$defs/replay" },
    "notes": { "type": "string" }
  },
  "$defs": {
    "identifier": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "endpoint": {
      "type": "object",
      "required": ["id", "label", "endpoint_type"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "endpoint_type": { "enum": ["ENTITY", "CLASS", "PROPERTY", "TABLE", "COLUMN", "API_FIELD", "JSON_FIELD", "ARTIFACT", "CONTEXT"] },
        "iri": { "type": "string" },
        "source_ref": { "type": "string" }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["evidence_type", "score", "detail"],
      "properties": {
        "evidence_type": { "enum": ["LEXICAL", "STRUCTURAL", "INSTANCE_LEVEL", "TEMPORAL", "PROVENANCE", "EMBEDDING", "RULE_DERIVED", "HUMAN_CURATED"] },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "detail": { "type": "string" },
        "source_ref": { "type": "string" }
      },
      "additionalProperties": false
    },
    "curation": {
      "type": "object",
      "required": ["review_status"],
      "properties": {
        "review_status": { "enum": ["NOT_REQUIRED", "REQUIRED", "PENDING", "APPROVED", "REJECTED", "ESCALATED"] },
        "reviewer_ref": { "type": "string" },
        "decision_ref": { "type": "string" },
        "active_learning_priority": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": ["admissibility_tier", "policy_basis"],
      "properties": {
        "admissibility_tier": { "enum": ["RAW", "VALIDATED", "GOVERNED", "CANONICAL"] },
        "policy_basis": { "type": "array", "items": { "type": "string" } },
        "export_eligible": { "type": "boolean" },
        "training_eligible": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "replay": {
      "type": "object",
      "required": ["inputs_hash", "config_hash", "replayable"],
      "properties": {
        "inputs_hash": { "type": "string" },
        "config_hash": { "type": "string" },
        "replayable": { "type": "boolean" },
        "created_at": { "$ref": "#/$defs/timestamp" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
